<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#2a1a3a"
    android:padding="16dp"
    android:elevation="10dp"
    android:alpha="0.95"
    android:minWidth="280dp">

    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_gravity="end"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#FF0000"
        android:background="@android:color/transparent"
        android:padding="4dp" />

    <Switch
        android:id="@+id/switch_macro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Activar Macro"
        android:textColor="#FFFFFF"
        android:thumbTint="#00FFFF"
        android:trackTint="#555555" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Velocidad (ms)"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

    <SeekBar
        android:id="@+id/seekbar_speed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="5" />

    <TextView
        android:id="@+id/tv_speed_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="50 ms"
        android:textColor="#00FFFF"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tamaño (dp)"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

    <SeekBar
        android:id="@+id/seekbar_size"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="80"
        android:progress="40" />

    <TextView
        android:id="@+id/tv_size_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="80 dp"
        android:textColor="#00FFFF"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transparencia (Alpha)"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

    <SeekBar
        android:id="@+id/seekbar_alpha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="205"
        android:progress="150" />

    <TextView
        android:id="@+id/tv_alpha_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="200"
        android:textColor="#00FFFF"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Borde (dp)"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

    <SeekBar
        android:id="@+id/seekbar_border"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="9"
        android:progress="3" />

    <TextView
        android:id="@+id/tv_border_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="4 dp"
        android:textColor="#00FFFF"
        android:gravity="center" />

    <Button
        android:id="@+id/btn_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cambiar Color"
        android:backgroundTint="#FF00FF"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

</LinearLayout>